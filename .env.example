# ---------------------------------------------------------------------------
# LLM Provider (ollama | openai | anthropic | vllm | llamacpp | groq | together)
# ---------------------------------------------------------------------------
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_API_KEY=
DEFAULT_MODEL=gemma4:26b
APP_NAME=local-llm-backend

# Legacy Ollama fallback (used when LLM_PROVIDER=ollama and LLM_BASE_URL is empty)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ---------------------------------------------------------------------------
# Dynatrace OTLP export (leave blank to run without observability export)
# ---------------------------------------------------------------------------
TRACELOOP_BASE_URL=
DT_OTLP_TOKEN=

# ---------------------------------------------------------------------------
# Open WebUI
# ---------------------------------------------------------------------------
WEBUI_SECRET_KEY=change-me-in-production

# ---------------------------------------------------------------------------
# Provider-specific examples (uncomment one block):
# ---------------------------------------------------------------------------

# --- Ollama (local, default) ---
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://host.docker.internal:11434
# DEFAULT_MODEL=gemma4:26b

# --- OpenAI ---
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com
# LLM_API_KEY=sk-...
# DEFAULT_MODEL=gpt-4o

# --- Anthropic ---
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.anthropic.com
# LLM_API_KEY=sk-ant-...
# DEFAULT_MODEL=claude-sonnet-4-20250514

# --- vLLM (local) ---
# LLM_PROVIDER=vllm
# LLM_BASE_URL=http://host.docker.internal:8000
# DEFAULT_MODEL=meta-llama/Llama-3-8B-Instruct

# --- Groq (cloud) ---
# LLM_PROVIDER=groq
# LLM_BASE_URL=https://api.groq.com/openai
# LLM_API_KEY=gsk_...
# DEFAULT_MODEL=llama-3.3-70b-versatile
