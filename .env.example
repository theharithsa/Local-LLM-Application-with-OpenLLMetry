# Ollama connection (running on host machine)
OLLAMA_BASE_URL=http://host.docker.internal:11434
DEFAULT_MODEL=gemma4:26b

# Dynatrace OTLP export (optional — leave blank to run without observability export)
TRACELOOP_BASE_URL=
DT_OTLP_TOKEN=

# Open WebUI session secret (change in production)
WEBUI_SECRET_KEY=change-me-in-production
