  "llm_base_url": "http://host.docker.internal:11434",
  "llm_api_key": "",
  "default_model": "gemma4:26b",
  "observability_backend": ["dynatrace", "jaeger", "none"],
  "otlp_endpoint": "",
  "backend_port": "8000",
  "frontend_port": "3000",
  "include_dashboard": ["yes", "no"],
  "include_rum": ["yes", "no"]
}
