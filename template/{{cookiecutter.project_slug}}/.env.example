# ---------------------------------------------------------------------------
# LLM Provider
# ---------------------------------------------------------------------------
LLM_PROVIDER={{ cookiecutter.llm_provider }}
LLM_BASE_URL={{ cookiecutter.llm_base_url }}
LLM_API_KEY={{ cookiecutter.llm_api_key }}
DEFAULT_MODEL={{ cookiecutter.default_model }}
APP_NAME={{ cookiecutter.app_name }}

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
{%- if cookiecutter.observability_backend == 'dynatrace' %}
# Dynatrace OTLP endpoint (e.g. https://your-env.apps.dynatrace.com/api/v2/otlp)
TRACELOOP_BASE_URL=
DT_OTLP_TOKEN=
{%- elif cookiecutter.observability_backend == 'jaeger' %}
# Jaeger via OTLP
TRACELOOP_BASE_URL=http://otel-collector:4318
{%- else %}
# No observability backend configured
{%- endif %}

# ---------------------------------------------------------------------------
# Open WebUI
# ---------------------------------------------------------------------------
WEBUI_SECRET_KEY=change-me-in-production
